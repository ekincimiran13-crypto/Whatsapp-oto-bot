const { Client, LocalAuth } = require('whatsapp-web.js');
const qrcode = require('qrcode-terminal');

const client = new Client({
    authStrategy: new LocalAuth(),
    puppeteer: {
        headless: true,
        args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage']
    }
});

// --- REKLAM MESAJINIZ ---
const MESAJ_ICERIGI = `👑 7/24 AKTİF PROFESYONEL SEARCH GRUBU

🎯 Kaliteli oyuncular
🎯 Hızlı takım bulma
🎯 Düzenli aktif ortam

💼 Ciddi oyuncuların tercihi

📌 Yerini hemen al:

https://chat.whatsapp.com/HXLzSDEQ1tc1OdVqEVd89Q?mode=gi_t`;
// -----------------------

let aktifGruplar = new Set(); // Mesaj gönderilen grupları takip eder

client.on('qr', qr => {
    console.log("QR LİNKİ: https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=" + encodeURIComponent(qr));
    qrcode.generate(qr, { small: true });
});

client.on('ready', () => {
    console.log('>>> BOT AKTİF! GRUPLARDAN MESAJ GELMESİ BEKLENİYOR... <<<');
});

// Herhangi bir gruptan mesaj geldiğinde tetiklenir
client.on('message', async (msg) => {
    const chat = await msg.getChat();
    
    // Eğer mesaj bir gruptan geldiyse ve bot bu grubu henüz listeye almadıysa
    if (chat.isGroup && !aktifGruplar.has(chat.id._serialized)) {
        aktifGruplar.add(chat.id._serialized);
        console.log(`YENİ HEDEF BELİRLENDİ: ${chat.name}. Reklam döngüsü başlıyor...`);
        
        // İlk reklamı hemen gönder
        client.sendMessage(chat.id._serialized, MESAJ_ICERIGI)
            .then(() => console.log(`İlk reklam başarıyla atıldı: ${chat.name}`))
            .catch(err => console.log(`Gönderim hatası (${chat.name}):`, err));
        
        // Bu grup için 3 dakikalık zamanlayıcıyı başlat
        setInterval(() => {
            client.sendMessage(chat.id._serialized, MESAJ_ICERIGI)
                .then(() => console.log(`3 dakikalık reklam atıldı: ${chat.name}`))
                .catch(err => console.log(`Döngü hatası (${chat.name}):`, err));
        }, 3 * 60 * 1000);
    }
});

client.initialize();
